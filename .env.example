# --------------------------------------------------------------------------- #
# Configuration du fournisseur LLM — copier en .env :  cp .env.example .env
# --------------------------------------------------------------------------- #
# Sans clé d'API, les notebooks tournent en mode HORS-LIGNE (MockLLMClient).
# Dès qu'une clé du fournisseur choisi est présente, les mêmes cellules
# appellent le vrai modèle.

# Fournisseur : openai | mistral | anthropic | google
LLM_PROVIDER=openai

# Modèle (optionnel). Par défaut selon le fournisseur :
#   openai    -> gpt-4o-mini
#   mistral   -> mistral-large-latest
#   anthropic -> claude-3-5-sonnet-latest
#   google    -> gemini-2.5-flash
# LLM_MODEL=gpt-4o-mini

# --- Clé d'API : renseigner UNIQUEMENT celle du fournisseur choisi ---------- #
OPENAI_API_KEY=
# MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
